PORT=3000

# ── Tipo de conexión: "direct" (sin SRV) | "srv" (con SRV) ───────────────────
MONGO_CONNECTION_TYPE=direct

# ── Credenciales (aplican para ambos tipos) ───────────────────────────────────
MONGO_USER=Arturo
MONGO_PASS=1234

# ── Conexión DIRECT (sin SRV) ─────────────────────────────────────────────────
MONGO_HOST0=ac-osoqmbj-shard-00-00.jy2fgtv.mongodb.net
MONGO_HOST1=ac-osoqmbj-shard-00-01.jy2fgtv.mongodb.net
MONGO_HOST2=ac-osoqmbj-shard-00-02.jy2fgtv.mongodb.net
MONGO_PORT=27017
MONGO_RS=atlas-116cyi-shard-0
MONGO_AUTH_DB=admin

# ── Conexión SRV (mongodb+srv://) ────────────────────────────────────────────
MONGO_SRV_HOST=cluster0.jy2fgtv.mongodb.net

# ── Base de datos (aplica para ambos tipos) ───────────────────────────────────
MONGO_DB=auth_service

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=CAMBIA_ESTE_SECRETO_POR_UNO_MUY_LARGO_Y_ALEATORIO
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=OTRO_SECRETO_DISTINTO_MUY_LARGO_Y_ALEATORIO
JWT_REFRESH_EXPIRES_IN=7d

# ── BCRYPT ────────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12

# ── Admin inicial (usado por scripts/seed.js) ─────────────────────────────────
SEED_ADMIN_NAME=Administrador
SEED_ADMIN_EMAIL=admin@empresa.com
SEED_ADMIN_PASSWORD=Admin123!
